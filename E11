using UnityEngine;

public class E11 : MonoBehaviour
{
    string estado;
    int vida;
    
    void Start()
    {
        if (vida < 20)
            estado = "Crítico";
        else if (vida >= 20 && vida <=50)
            estado = "Herido";
        else
            estado = "Estable";

        estado = (vida < 20) ? "Crítico" : ((vida >= 20) && (vida <=50)) ? "Herido" : "Estable";
    }
    
    void Update()
    {
        
    }
}
